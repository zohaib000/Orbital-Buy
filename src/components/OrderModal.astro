---
import { product } from "../data/product";
import { site } from "../data/site";

const countries = [
  "United States", "Canada", "United Kingdom", "Australia", "New Zealand",
  "Germany", "France", "Netherlands", "Ireland", "United Arab Emirates",
  "Pakistan", "India", "Other",
];
---

<dialog
  id="order-modal"
  class="m-auto max-h-[90vh] w-[92vw] max-w-lg overflow-y-auto rounded-sm border border-steel-light bg-steel p-0 text-paper backdrop:bg-ink/85 backdrop:backdrop-blur-sm"
>
  <div class="relative p-6 sm:p-7">
    <button
      type="button"
      data-close-order
      aria-label="Close"
      class="absolute right-4 top-4 font-mono text-xl leading-none text-chrome transition-colors hover:text-safety"
    >
      &times;
    </button>

    <!-- Step 1: checkout form -->
    <form id="order-form" data-step="details">
      <p class="font-mono text-xs uppercase tracking-widest text-rust-bright">Secure Checkout</p>
      <h3 class="font-display mt-1 text-xl font-semibold uppercase tracking-wide text-paper">
        Shipping details
      </h3>
      <div class="mt-2 flex items-center gap-2 rounded-sm border border-steel-light bg-ink px-3 py-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f0b429" stroke-width="2" class="shrink-0">
          <rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <p class="text-xs text-chrome">
          Ordering: <span class="text-paper">{product.name}</span> ·
          <span id="order-color-label" class="text-safety">{product.colors[0].label}</span>
        </p>
      </div>
      <input type="hidden" name="color" id="order-color-input" value={product.colors[0].label} />

      <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <label class="block sm:col-span-2">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Full name</span>
          <input
            type="text" name="fullName" required autocomplete="name" placeholder="Jane Smith"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Email</span>
          <input
            type="email" name="email" required autocomplete="email" placeholder="you@example.com"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Phone number</span>
          <input
            type="tel" name="phone" required autocomplete="tel" placeholder="+1 555 123 4567"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Address line 1</span>
          <input
            type="text" name="address1" required autocomplete="address-line1" placeholder="Street address"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block sm:col-span-2">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Address line 2 <span class="text-chrome/60">(optional)</span></span>
          <input
            type="text" name="address2" autocomplete="address-line2" placeholder="Apartment, suite, etc."
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">City</span>
          <input
            type="text" name="city" required autocomplete="address-level2" placeholder="City"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">State / Province</span>
          <input
            type="text" name="state" required autocomplete="address-level1" placeholder="State"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">ZIP / Postal code</span>
          <input
            type="text" name="zip" required autocomplete="postal-code" placeholder="ZIP code"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          />
        </label>

        <label class="block">
          <span class="font-mono text-[11px] uppercase tracking-wider text-chrome">Country</span>
          <select
            name="country" required autocomplete="country-name"
            class="mt-1 w-full rounded-sm border border-steel-light bg-ink px-3 py-2.5 text-sm text-paper outline-none focus:border-safety"
          >
            <option value="" disabled selected>Select country</option>
            {countries.map((c) => <option value={c}>{c}</option>)}
          </select>
        </label>
      </div>

      <div class="mt-4 flex items-center gap-2 font-mono text-[11px] text-chrome">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#9aa5ac" stroke-width="2">
          <rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        Your information is only used to process and ship this order.
      </div>

      <p id="order-error" class="mt-3 hidden text-xs text-rust-bright"></p>

      <button
        type="submit"
        id="order-submit"
        class="font-display mt-5 w-full rounded-sm bg-safety px-6 py-3 text-base font-semibold uppercase tracking-wide text-ink shadow-[4px_4px_0_0_theme(colors.rust)] transition-transform hover:-translate-y-0.5 active:translate-y-0 disabled:opacity-60"
      >
        Continue to Payment
      </button>
    </form>

    <!-- Step 2: confirmation -->
    <div data-step="success" class="hidden">
      <p class="font-mono text-xs uppercase tracking-widest text-safety">Order Started</p>
      <h3 class="font-display mt-1 text-xl font-semibold uppercase tracking-wide text-paper">Almost done!</h3>
      <p class="mt-2.5 text-sm leading-relaxed text-chrome">
        We opened the payment page in a new tab — finish checkout there to confirm your order.
      </p>

      <button
        type="button"
        data-close-order
        class="font-display mt-6 w-full rounded-sm bg-safety px-6 py-3 text-sm font-semibold uppercase tracking-wide text-ink shadow-[4px_4px_0_0_theme(colors.rust)] transition-transform hover:-translate-y-0.5 active:translate-y-0"
      >
        Done
      </button>
    </div>
  </div>
</dialog>

<script
  define:vars={{
    gumroadLink: product.gumroadLink,
    formEndpoint: site.formEndpoint,
    productName: product.name,
  }}
>
  const modal = document.getElementById("order-modal");
  const form = document.getElementById("order-form");
  const submitBtn = document.getElementById("order-submit");
  const errorEl = document.getElementById("order-error");
  const colorLabelEl = document.getElementById("order-color-label");
  const colorInputEl = document.getElementById("order-color-input");
  const detailsStep = modal?.querySelector('[data-step="details"]');
  const successStep = modal?.querySelector('[data-step="success"]');

  // Keep the modal's color in sync with whatever the hero swatch picker last set.
  window.addEventListener("petbag:color-selected", (e) => {
    const label = e.detail?.label;
    if (!label) return;
    if (colorLabelEl) colorLabelEl.textContent = label;
    if (colorInputEl instanceof HTMLInputElement) colorInputEl.value = label;
  });

  const openModal = () => {
    if (!(modal instanceof HTMLDialogElement)) return;
    detailsStep?.classList.remove("hidden");
    successStep?.classList.add("hidden");
    errorEl?.classList.add("hidden");
    if (form instanceof HTMLFormElement) form.reset();
    // form.reset() clears the hidden color input's dynamic value back to its
    // original default — restore whatever was last selected in the hero.
    if (colorInputEl instanceof HTMLInputElement && colorLabelEl) {
      colorInputEl.value = colorLabelEl.textContent || colorInputEl.value;
    }
    modal.showModal();
  };

  const closeModal = () => {
    if (modal instanceof HTMLDialogElement) modal.close();
  };

  // Any element on the page with data-open-order opens this modal.
  document.querySelectorAll("[data-open-order]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      openModal();
    });
  });

  modal?.querySelectorAll("[data-close-order]").forEach((el) => {
    el.addEventListener("click", closeModal);
  });

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!(form instanceof HTMLFormElement) || !(submitBtn instanceof HTMLButtonElement)) return;

    const data = new FormData(form);
    const payload = Object.fromEntries(data.entries());
    const email = String(payload.email || "").trim();

    submitBtn.disabled = true;
    submitBtn.textContent = "Saving...";

    try {
      if (formEndpoint.includes("REPLACE_WITH_YOUR_FORM_ID")) {
        console.warn("OrbitalBuy: set a real Formspree endpoint in src/data/site.ts to save customer data.");
      } else {
        await fetch(formEndpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({ product: productName, ...payload }),
        });
      }
    } catch (err) {
      console.error("OrbitalBuy: failed to save customer data", err);
    }

    const gumroadUrl = `${gumroadLink}?wanted=true&email=${encodeURIComponent(email)}`;
    window.open(gumroadUrl, "_blank", "noopener");

    detailsStep?.classList.add("hidden");
    successStep?.classList.remove("hidden");
    submitBtn.disabled = false;
    submitBtn.textContent = "Continue to Payment";
  });
</script>
