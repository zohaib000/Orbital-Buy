---
import { product } from "../data/product";
---

<section id="order" class="bg-steel py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <div class="mb-10 text-center">
      <span class="font-mono text-xs uppercase tracking-widest text-rust-bright">Order Ticket</span>
      <h2 class="font-display mt-2 text-3xl font-semibold uppercase tracking-tight text-paper sm:text-4xl">
        Lock in the sale price
      </h2>
    </div>

    <div class="relative mx-1 rounded-sm border border-safety/40 bg-ink shadow-[6px_6px_0_0_theme(colors.rust)]">
      <!-- corner badge -->
      <span class="font-display absolute -top-3 left-6 rounded-sm bg-rust px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-paper shadow-[2px_2px_0_0_theme(colors.safety)]">
        {product.discountPercent}% Off Today
      </span>

      <!-- outer edge notches, like a torn ticket stub -->
      <span class="pointer-events-none absolute -left-3 top-1/2 hidden h-6 w-6 -translate-y-1/2 rounded-full bg-steel sm:block"></span>
      <span class="pointer-events-none absolute -right-3 top-1/2 hidden h-6 w-6 -translate-y-1/2 rounded-full bg-steel sm:block"></span>

      <div class="grid grid-cols-1 sm:grid-cols-[1.3fr_1fr]">
        <!-- left: product -->
        <div class="p-6 sm:p-8">
          <div class="flex gap-4">
            <img src={product.images[0]} alt={product.name} class="h-20 w-20 shrink-0 rounded-sm border border-steel-light object-cover" />
            <div>
              <p class="font-mono text-[11px] uppercase tracking-widest text-chrome">{product.brand} · {product.seller}</p>
              <h3 class="font-display mt-1 text-lg font-semibold uppercase leading-tight text-paper">{product.name}</h3>
              <p class="mt-1 font-mono text-xs text-chrome">{product.capacity}</p>
            </div>
          </div>

          <dl class="mt-6 space-y-2.5 border-t border-dashed border-steel-light/60 pt-5 font-mono text-sm">
            <div class="flex justify-between text-chrome">
              <dt>Unit price</dt>
              <dd class="text-paper">{product.currency}{product.price}</dd>
            </div>
            <div class="flex justify-between text-chrome">
              <dt>List price</dt>
              <dd class="text-paper line-through decoration-rust-bright/70">{product.currency}{product.compareAtPrice}</dd>
            </div>
            <div class="flex justify-between text-chrome">
              <dt>Estimated delivery</dt>
              <dd class="text-paper">{product.deliveryWindow}</dd>
            </div>
            <div class="flex justify-between text-chrome">
              <dt>Shipping</dt>
              <dd class="text-safety">Free</dd>
            </div>
          </dl>
        </div>

        <!-- right: CTA stub -->
        <div class="relative flex flex-col justify-center gap-5 border-t border-dashed border-safety/40 bg-steel p-6 sm:border-l sm:border-t-0 sm:p-8">
          <!-- seam notches marking the tear-line -->
          <span class="pointer-events-none absolute -left-3 -top-3 hidden h-6 w-6 rounded-full bg-steel sm:block"></span>
          <span class="pointer-events-none absolute -left-3 -bottom-3 hidden h-6 w-6 rounded-full bg-steel sm:block"></span>

          <div>
            <p class="font-mono text-[11px] uppercase tracking-widest text-chrome">Sale ends</p>
            <p class="font-display text-lg font-semibold text-safety">{product.saleEndsLabel}</p>
          </div>

          <div class="flex items-center gap-3">
            <span class="font-mono text-xs uppercase tracking-widest text-chrome">Qty</span>
            <div class="flex items-center rounded-sm border border-steel-light">
              <button id="qty-minus" type="button" class="px-3 py-1.5 font-mono text-paper transition-colors hover:text-safety" aria-label="Decrease quantity">−</button>
              <span id="qty-value" class="w-8 text-center font-mono text-paper">1</span>
              <button id="qty-plus" type="button" class="px-3 py-1.5 font-mono text-paper transition-colors hover:text-safety" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <div class="flex items-baseline justify-between">
            <span class="font-mono text-xs uppercase tracking-widest text-chrome">Total</span>
            <span id="qty-total" class="font-display text-2xl font-semibold text-paper">{product.currency}{product.price}</span>
          </div>

          <button
            type="button"
            data-open-order
            class="font-display inline-flex items-center justify-center rounded-sm bg-safety px-6 py-3.5 text-base font-semibold uppercase tracking-wide text-ink shadow-[4px_4px_0_0_theme(colors.rust)] transition-transform hover:-translate-y-0.5 active:translate-y-0"
          >
            Order Now
          </button>
          <p class="text-center font-mono text-[11px] uppercase tracking-wider text-chrome">
            Free returns · 90-day window
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ price: product.price, currency: product.currency }}>
  const minus = document.getElementById("qty-minus");
  const plus = document.getElementById("qty-plus");
  const value = document.getElementById("qty-value");
  const total = document.getElementById("qty-total");
  let qty = 1;
  const render = () => {
    value.textContent = String(qty);
    total.textContent = `${currency}${(price * qty).toFixed(2)}`;
  };
  minus?.addEventListener("click", () => {
    qty = Math.max(1, qty - 1);
    render();
  });
  plus?.addEventListener("click", () => {
    qty = Math.min(20, qty + 1);
    render();
  });
</script>
