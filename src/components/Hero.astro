---
import { product } from "../data/product";
---

<section id="top" class="relative overflow-hidden bg-ink pt-10 sm:pt-14">
  <!-- ambient grid texture -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.06]"
    style="background-image: linear-gradient(var(--color-chrome) 1px, transparent 1px), linear-gradient(90deg, var(--color-chrome) 1px, transparent 1px); background-size: 42px 42px;"
  >
  </div>

  <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 px-5 pb-16 sm:px-8 lg:grid-cols-2 lg:gap-8 lg:pb-24">
    <!-- Left: stencil copy -->
    <div>
      <div class="mb-5 inline-flex items-center gap-2 rounded-sm border border-safety/40 bg-safety/10 px-3 py-1 font-mono text-xs uppercase tracking-widest text-safety">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-safety"></span>
        Part No. {product.brand}-RRS100 · Big Sale
      </div>

      <h1 class="font-display stencil-shadow text-4xl font-semibold uppercase leading-[1.05] tracking-tight text-paper sm:text-5xl lg:text-6xl">
        Rust doesn't
        <br />
        <span class="text-rust-bright">stand a chance.</span>
      </h1>

      <p class="mt-5 max-w-md text-[15px] leading-relaxed text-chrome sm:text-base">
        {product.description}
      </p>

      <div class="mt-7 flex flex-wrap items-end gap-4">
        <div class="font-mono">
          <div class="text-xs uppercase tracking-widest text-chrome line-through decoration-rust-bright/70">
            {product.currency}{product.compareAtPrice}
          </div>
          <div class="font-display text-4xl font-semibold text-safety">
            {product.currency}{product.price}
          </div>
        </div>
        <span class="mb-1 rounded-sm bg-rust px-2.5 py-1 font-mono text-xs font-semibold uppercase tracking-wide text-paper">
          {product.discountPercent}% off
        </span>
      </div>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <button
          type="button"
          data-open-order
          class="font-display inline-flex items-center justify-center rounded-sm bg-safety px-7 py-3.5 text-base font-semibold uppercase tracking-wide text-ink shadow-[4px_4px_0_0_theme(colors.rust)] transition-transform hover:-translate-y-0.5 active:translate-y-0"
        >
          Order Now
        </button>
        <a
          href="#features"
          class="font-mono inline-flex items-center justify-center rounded-sm border border-chrome/40 px-7 py-3.5 text-sm uppercase tracking-wide text-paper transition-colors hover:border-safety hover:text-safety"
        >
          See Specs
        </a>
      </div>

      <p class="mt-5 font-mono text-xs uppercase tracking-wider text-chrome">
        {product.unitsSold} sold · {product.rating} / 5 from {product.reviewCount} reviews
      </p>
    </div>

    <!-- Right: rust-wipe reveal -->
    <div class="relative mx-auto w-full max-w-md">
      <div
        id="wipe-frame"
        class="group relative aspect-square select-none overflow-hidden rounded-sm border border-steel-light bg-steel"
      >
        <!-- clean image (bottom layer, fully visible) -->
        <img
          src={product.images[0]}
          alt={product.name}
          class="absolute inset-0 h-full w-full object-cover"
          loading="eager"
        />

        <!-- rusted overlay (top layer, clipped by slider) -->
        <div id="wipe-overlay" class="absolute inset-0 h-full w-full" style="clip-path: inset(0 35% 0 0);">
          <img
            src={product.images[0]}
            alt=""
            aria-hidden="true"
            class="h-full w-full object-cover"
            style="filter: sepia(0.65) saturate(2.6) hue-rotate(-18deg) brightness(0.82) contrast(1.1);"
          />
          <svg class="absolute inset-0 h-full w-full opacity-70 mix-blend-multiply" xmlns="http://www.w3.org/2000/svg">
            <filter id="rustNoise">
              <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" seed="7" stitchTiles="stitch"></feTurbulence>
              <feColorMatrix type="matrix" values="0.7 0 0 0 0  0.3 0 0 0 0  0.05 0 0 0 0  0 0 0 0.85 0"></feColorMatrix>
            </filter>
            <rect width="100%" height="100%" filter="url(#rustNoise)"></rect>
          </svg>
        </div>

        <!-- drag handle -->
        <div id="wipe-handle" class="absolute inset-y-0 flex w-8 -translate-x-1/2 cursor-ew-resize items-center justify-center" style="left: 65%;">
          <div class="h-full w-0.5 bg-safety/80"></div>
          <div class="absolute flex h-9 w-9 items-center justify-center rounded-full border-2 border-safety bg-ink shadow-lg">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f0b429" stroke-width="2.5">
              <path d="M8 6 L2 12 L8 18" /><path d="M16 6 L22 12 L16 18" />
            </svg>
          </div>
        </div>
      </div>

      <div class="mt-3 flex justify-between font-mono text-[11px] uppercase tracking-widest text-chrome">
        <span>← Rusted</span>
        <span>Drag to reveal</span>
        <span>Treated →</span>
      </div>
    </div>
  </div>
</section>

<script>
  const frame = document.getElementById("wipe-frame");
  const overlay = document.getElementById("wipe-overlay");
  const handle = document.getElementById("wipe-handle");
  if (frame && overlay && handle) {
    let dragging = false;

    const setPct = (clientX: number) => {
      const rect = frame.getBoundingClientRect();
      let pct = ((clientX - rect.left) / rect.width) * 100;
      pct = Math.max(4, Math.min(96, pct));
      overlay.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
      handle.style.left = `${pct}%`;
    };

    const start = () => (dragging = true);
    const stop = () => (dragging = false);
    const move = (e: MouseEvent) => dragging && setPct(e.clientX);
    const moveTouch = (e: TouchEvent) => {
      if (dragging && e.touches[0]) setPct(e.touches[0].clientX);
    };

    handle.addEventListener("mousedown", start);
    frame.addEventListener("mousedown", (e) => {
      start();
      setPct((e as MouseEvent).clientX);
    });
    window.addEventListener("mouseup", stop);
    window.addEventListener("mousemove", move);

    handle.addEventListener("touchstart", start, { passive: true });
    frame.addEventListener("touchstart", (e: TouchEvent) => {
      start();
      if (e.touches[0]) setPct(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener("touchend", stop);
    window.addEventListener("touchmove", moveTouch, { passive: true });

    // gentle auto-demo sweep on load, then hand control to the user
    let auto = 35;
    let dir = 1;
    let sweeps = 0;
    const interval = setInterval(() => {
      if (dragging) return;
      auto += dir * 0.6;
      if (auto > 75 || auto < 25) {
        dir *= -1;
        sweeps++;
      }
      overlay.style.clipPath = `inset(0 ${100 - auto}% 0 0)`;
      handle.style.left = `${auto}%`;
      if (sweeps >= 3) clearInterval(interval);
    }, 30);
  }
</script>
