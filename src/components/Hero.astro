---
import { product } from "../data/product";
---

<section id="top" class="relative overflow-hidden bg-ink pt-10 sm:pt-14">
  <!-- ambient grid texture -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.06]"
    style="background-image: linear-gradient(var(--color-chrome) 1px, transparent 1px), linear-gradient(90deg, var(--color-chrome) 1px, transparent 1px); background-size: 42px 42px;"
  >
  </div>

  <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 px-5 pb-16 sm:px-8 lg:grid-cols-2 lg:gap-8 lg:pb-24">
    <!-- Left: copy -->
    <div>
      <div class="mb-5 inline-flex items-center gap-2 rounded-sm border border-safety/40 bg-safety/10 px-3 py-1 font-mono text-xs uppercase tracking-widest text-safety">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-safety"></span>
        {product.discountPercent}% Off · 9 Styles In Stock
      </div>

      <h1 class="font-display stencil-shadow text-4xl font-semibold uppercase leading-[1.05] tracking-tight text-paper sm:text-5xl lg:text-6xl">
        {product.name}
      </h1>

      <p class="mt-5 max-w-md text-[15px] leading-relaxed text-chrome sm:text-base">
        {product.tagline}
      </p>

      <div class="mt-7 flex flex-wrap items-end gap-4">
        <div class="font-mono">
          <div class="text-xs uppercase tracking-widest text-chrome line-through decoration-rust-bright/70">
            {product.currency}{product.compareAtPrice}
          </div>
          <div class="font-display text-4xl font-semibold text-safety">
            {product.currency}{product.price}
          </div>
        </div>
        <span class="mb-1 rounded-sm bg-rust px-2.5 py-1 font-mono text-xs font-semibold uppercase tracking-wide text-paper">
          {product.discountPercent}% off
        </span>
      </div>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <button
          type="button"
          data-open-order
          class="font-display inline-flex items-center justify-center rounded-sm bg-safety px-7 py-3.5 text-base font-semibold uppercase tracking-wide text-ink shadow-[4px_4px_0_0_theme(colors.rust)] transition-transform hover:-translate-y-0.5 active:translate-y-0"
        >
          Order Now
        </button>
        <a
          href="#features"
          class="font-mono inline-flex items-center justify-center rounded-sm border border-chrome/40 px-7 py-3.5 text-sm uppercase tracking-wide text-paper transition-colors hover:border-safety hover:text-safety"
        >
          See Details
        </a>
      </div>

      <p class="mt-5 font-mono text-xs uppercase tracking-wider text-chrome">
        {product.rating} / 5 · {product.reviewCount} verified review
      </p>
    </div>

    <!-- Right: main image + color picker -->
    <div class="relative mx-auto w-full max-w-md">
      <div class="relative aspect-square overflow-hidden rounded-sm border border-steel-light bg-steel">
        <img
          id="hero-main-image"
          src={product.colors[0].image}
          alt={`${product.name} — ${product.colors[0].label}`}
          class="h-full w-full object-cover"
          loading="eager"
        />
        <span
          id="hero-color-badge"
          class="absolute left-3 top-3 rounded-sm bg-ink/80 px-2.5 py-1 font-mono text-[11px] uppercase tracking-wider text-safety backdrop-blur-sm"
        >
          {product.colors[0].label}
        </span>
      </div>

      <div class="mt-4">
        <p class="mb-2 font-mono text-[11px] uppercase tracking-widest text-chrome">Choose a style</p>
        <div class="flex flex-wrap gap-2">
          {
            product.colors.map((c, i) => (
              <button
                type="button"
                class="hero-swatch group relative h-12 w-12 overflow-hidden rounded-sm border-2 border-steel-light transition-colors data-[active=true]:border-safety"
                data-image={c.image}
                data-label={c.label}
                data-active={i === 0 ? "true" : "false"}
                aria-label={`Select ${c.label}`}
                title={c.label}
              >
                <img src={c.image} alt="" class="h-full w-full object-cover" loading="lazy" />
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const mainImage = document.getElementById("hero-main-image");
  const colorBadge = document.getElementById("hero-color-badge");
  const swatches = document.querySelectorAll(".hero-swatch");

  swatches.forEach((swatch) => {
    swatch.addEventListener("click", () => {
      const image = swatch.getAttribute("data-image");
      const label = swatch.getAttribute("data-label");
      if (image && mainImage instanceof HTMLImageElement) mainImage.src = image;
      if (label && colorBadge) colorBadge.textContent = label;

      swatches.forEach((s) => s.setAttribute("data-active", "false"));
      swatch.setAttribute("data-active", "true");

      // Let the order form know which style is currently selected.
      window.dispatchEvent(new CustomEvent("petbag:color-selected", { detail: { label } }));
    });
  });
</script>
