---
import { product } from "../data/product";
import { site } from "../data/site";
---

<header class="sticky top-0 z-50 border-b border-steel-light/60 bg-ink/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3.5 sm:px-8">
    <a href="#top" class="flex items-center gap-2.5">
      <svg width="26" height="26" viewBox="0 0 64 64" class="shrink-0">
        <path d="M32 6 L52 42 A20 20 0 1 1 12 42 Z" fill="#b3491f"/>
        <path d="M32 20 L43 42 A11 11 0 1 1 21 42 Z" fill="#f0b429"/>
      </svg>
      <span class="font-display text-lg font-semibold tracking-wide text-paper">
        ORBITAL<span class="text-rust-bright">BUY</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 font-mono text-[13px] uppercase tracking-wider text-chrome md:flex">
      <a href="#demo" class="transition-colors hover:text-safety">Demo</a>
      <a href="#features" class="transition-colors hover:text-safety">Specs</a>
      <a href="#gallery" class="transition-colors hover:text-safety">Gallery</a>
      <a href="#reviews" class="transition-colors hover:text-safety">Field Reports</a>
      <a href="#faq" class="transition-colors hover:text-safety">FAQ</a>
    </nav>

    <button
      type="button"
      data-open-order
      class="font-display rounded-sm bg-rust px-4 py-2 text-sm font-semibold uppercase tracking-wide text-paper shadow-[3px_3px_0_0_theme(colors.safety)] transition-transform hover:-translate-y-0.5 sm:px-5"
    >
      Order · {product.currency}{product.price}
    </button>
  </div>
</header>
