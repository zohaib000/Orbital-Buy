---
import { site } from "../data/site";

const year = new Date().getFullYear();
const payments = ["Visa", "Mastercard", "Amex", "PayPal", "Gumroad"];
---

<footer class="border-t border-steel-light/60 bg-steel py-12">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
      <div class="max-w-xs">
        <span class="font-display text-lg font-semibold tracking-wide text-paper">
          ORBITAL<span class="text-rust-bright">BUY</span>
        </span>
        <p class="mt-3 text-sm leading-relaxed text-chrome">
          Sourcing well-reviewed products from overseas marketplaces and shipping them to your door, with guaranteed delivery on every order.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 font-mono text-xs text-chrome sm:grid-cols-3">
        <div>
          <p class="mb-3 uppercase tracking-wider text-paper">Support</p>
          <ul class="space-y-3">
            <li>
              <span class="block text-[10px] uppercase tracking-wider text-chrome/70">WhatsApp</span>
              <a
                href={`https://wa.me/${site.whatsapp}`}
                target="_blank"
                rel="noopener"
                class="normal-case tracking-normal text-paper transition-colors hover:text-safety"
              >
                {site.whatsappDisplay}
              </a>
            </li>
            <li>
              <span class="block text-[10px] uppercase tracking-wider text-chrome/70">Email</span>
              <a
                href={`mailto:${site.supportEmail}`}
                class="lowercase tracking-normal text-paper transition-colors hover:text-safety break-all"
              >
                {site.supportEmail}
              </a>
            </li>
            <li class="uppercase tracking-wider">Returns &amp; Refunds</li>
          </ul>
        </div>
        <div>
          <p class="mb-3 uppercase tracking-wider text-paper">Company</p>
          <ul class="space-y-2 uppercase tracking-wider">
            <li>About</li>
            <li>Report an Issue</li>
            <li>Sitemap</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-4 border-t border-steel-light/60 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono text-[11px] uppercase tracking-wider text-chrome">© {year} {site.domain}. All rights reserved.</p>
      <div class="flex flex-wrap gap-2 font-mono text-[10px] uppercase tracking-wider text-chrome">
        {payments.map((p) => <span class="rounded-sm border border-steel-light px-2 py-1">{p}</span>)}
      </div>
    </div>
  </div>
</footer>
