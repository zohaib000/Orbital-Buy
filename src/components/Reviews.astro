---
import { product } from "../data/product";

const countryFlags: Record<string, string> = {
  "United States": "🇺🇸",
  "United Kingdom": "🇬🇧",
  "United Arab Emirates": "🇦🇪",
  "Australia": "🇦🇺",
};
---

<section id="reviews" class="bg-ink py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="mb-12 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <span class="font-mono text-xs uppercase tracking-widest text-safety">Field Reports</span>
        <h2 class="font-display mt-2 text-3xl font-semibold uppercase tracking-tight text-paper sm:text-4xl">
          From buyers worldwide
        </h2>
      </div>
      <div class="font-mono text-sm text-chrome">
        <span class="text-2xl font-semibold text-safety">{product.rating}</span> / 5 · {product.reviewCount.toLocaleString()} reviews
      </div>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        product.reviews.map((r) => (
          <div class="group relative rounded-sm border border-steel-light bg-steel p-5 transition-colors hover:border-rust-bright/60">
            <span class="pointer-events-none absolute right-4 top-3 font-display text-5xl leading-none text-steel-light/40 transition-colors group-hover:text-rust-bright/25">
              "
            </span>

            <div class="mb-4 flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-rust font-mono text-xs font-semibold text-paper">
                {r.initials}
              </div>
              <div class="min-w-0">
                <p class="truncate font-display text-sm font-semibold uppercase tracking-wide text-paper">{r.name}</p>
                <p class="truncate font-mono text-[11px] uppercase tracking-wide text-chrome">
                  {countryFlags[r.country] ?? "🌍"} {r.country}
                </p>
              </div>
            </div>

            <div class="mb-2.5 flex items-center justify-between">
              <span class="font-mono text-xs text-safety">{"★".repeat(r.rating)}{"☆".repeat(5 - r.rating)}</span>
              <span class="font-mono text-[10px] uppercase tracking-wide text-chrome/70">{r.date}</span>
            </div>

            <p class="relative text-sm leading-relaxed text-paper/90">{r.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
