---
import { product } from "../data/product";
---

<section class="border-y border-steel-light/60 bg-steel">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-px bg-steel-light/40 sm:grid-cols-4">
    {
      product.trust.map((t) => (
        <div class="flex flex-col gap-1 bg-steel px-5 py-5 sm:px-6">
          <span class="font-display text-sm font-semibold uppercase tracking-wide text-safety">{t.label}</span>
          <span class="font-mono text-[11px] uppercase tracking-wide text-chrome">{t.detail}</span>
        </div>
      ))
    }
  </div>
</section>
