---
import { product } from "../data/product";
---

<section id="faq" class="bg-ink py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-5 sm:px-8">
    <span class="font-mono text-xs uppercase tracking-widest text-rust-bright">FAQ</span>
    <h2 class="font-display mt-2 mb-10 text-3xl font-semibold uppercase tracking-tight text-paper sm:text-4xl">
      Before you order
    </h2>

    <div class="divide-y divide-steel-light/60 border-y border-steel-light/60">
      {
        product.faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
              <span class="font-display text-base font-medium uppercase tracking-wide text-paper sm:text-lg">{f.q}</span>
              <span class="font-mono shrink-0 text-xl text-safety transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-chrome">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
